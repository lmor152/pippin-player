---
/**
 * Nav — sticky top navigation with a glass/blur background that intensifies on
 * scroll. Wordmark left, anchor links centre, Apple-style "Download" pill right.
 * Mobile collapses the links into a simple toggle menu.
 *
 * Placeholder App Store link (href="#") — the app is treated as released.
 */
import Wordmark from './Wordmark.astro';

const links = [
  { label: 'Features', href: '#features' },
  { label: 'Customise', href: '#customise' },
  { label: 'Player', href: '#player' },
  { label: 'Integrations', href: '#integrations' },
  { label: 'Community', href: '#community' },
];
---
<header class="nav" id="site-nav" data-scrolled="false">
  <div class="container nav__inner">
    <Wordmark size={22} href="#top" class="nav__brand" />

    <nav class="nav__links" aria-label="Primary">
      {links.map((l) => (
        <a href={l.href} class="nav__link">{l.label}</a>
      ))}
    </nav>

    <div class="nav__actions">
      <a href="#" class="btn btn-primary nav__download">Download</a>
      <button
        class="nav__toggle"
        type="button"
        aria-label="Menu"
        aria-expanded="false"
        aria-controls="nav-mobile"
      >
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <nav class="nav__mobile" id="nav-mobile" aria-label="Mobile" hidden>
    {links.map((l) => (
      <a href={l.href} class="nav__mobile-link">{l.label}</a>
    ))}
    <a href="#" class="btn btn-primary nav__mobile-download">Download</a>
  </nav>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: transparent;
    border-bottom: 1px solid transparent;
    transition:
      background-color var(--dur) var(--ease-out),
      border-color var(--dur) var(--ease-out),
      backdrop-filter var(--dur) var(--ease-out);
  }
  .nav[data-scrolled='true'] {
    background-color: var(--glass-strong);
    border-bottom-color: var(--glass-border);
    backdrop-filter: blur(20px) saturate(1.6);
    -webkit-backdrop-filter: blur(20px) saturate(1.6);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    height: var(--nav-height);
  }

  .nav__links {
    display: flex;
    align-items: center;
    gap: var(--space-5);
  }
  .nav__link {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--label-secondary);
    transition: color var(--dur-fast) var(--ease-out);
  }
  .nav__link:hover {
    color: var(--label);
  }

  .nav__actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  /* Mobile toggle */
  .nav__toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    padding: 0;
    background: transparent;
    border: none;
  }
  .nav__toggle span {
    display: block;
    width: 20px;
    height: 2px;
    margin-inline: auto;
    border-radius: 2px;
    background-color: var(--label);
    transition: transform var(--dur-fast) var(--ease-out),
      opacity var(--dur-fast) var(--ease-out);
  }
  .nav[data-menu-open='true'] .nav__toggle span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav[data-menu-open='true'] .nav__toggle span:nth-child(2) {
    opacity: 0;
  }
  .nav[data-menu-open='true'] .nav__toggle span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .nav__mobile {
    display: none;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-4) var(--content-pad) var(--space-6);
    background-color: var(--glass-strong);
    border-bottom: 1px solid var(--glass-border);
    backdrop-filter: blur(20px) saturate(1.6);
    -webkit-backdrop-filter: blur(20px) saturate(1.6);
  }
  .nav__mobile-link {
    padding: var(--space-3) 0;
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--label);
    border-bottom: 1px solid var(--hairline);
  }
  .nav__mobile-download {
    margin-top: var(--space-3);
    align-self: flex-start;
  }

  @media (max-width: 820px) {
    .nav__links,
    .nav__download {
      display: none;
    }
    .nav__toggle {
      display: flex;
    }
    .nav[data-menu-open='true'] .nav__mobile {
      display: flex;
    }
  }
</style>

<script>
  // Intensify the glass background once the page has scrolled.
  const nav = document.getElementById('site-nav');
  if (nav) {
    const onScroll = () => {
      nav.dataset.scrolled = window.scrollY > 8 ? 'true' : 'false';
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });

    // Mobile menu toggle.
    const toggle = nav.querySelector<HTMLButtonElement>('.nav__toggle');
    const mobile = document.getElementById('nav-mobile');
    const setOpen = (open: boolean) => {
      nav.dataset.menuOpen = String(open);
      toggle?.setAttribute('aria-expanded', String(open));
      if (mobile) mobile.hidden = !open;
    };
    toggle?.addEventListener('click', () => {
      setOpen(nav.dataset.menuOpen !== 'true');
    });
    // Close after choosing a link.
    mobile?.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => setOpen(false))
    );
  }
</script>
