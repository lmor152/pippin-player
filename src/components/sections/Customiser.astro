    }
    .cz-seg > [role="radio"] {
      position: relative; z-index: 1;
      appearance: none; border: 0; background: transparent; cursor: pointer;
      padding: 0.5em 0.35em;
      font-family: var(--font-body); font-weight: 600; font-size: 0.8125rem;
      color: var(--label-secondary);
