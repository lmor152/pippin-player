    .cz-preview[data-layout="sidebar"] .cz-stage { border-radius: 22px; }

    /* Content column */
    .cz-content { position: relative; flex: 1; min-width: 0; display: flex; flex-direction: column; }

    /* Status bar */
    .cz-statusbar {
