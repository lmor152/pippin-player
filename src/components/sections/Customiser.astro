    .cz-swatch-custom input[type="color"] {
      position: absolute; inset: 0; width: 100%; height: 100%;
      opacity: 0; cursor: pointer; border: 0; padding: 0;
    }
    .cz-swatch-custom[data-active="true"] .cz-custom-dot { box-shadow: 0 0 0 2px var(--accent), inset 0 0 0 1px rgba(255,255,255,0.22); }

    /* Segmented controls */
    .cz-seg {
      position: relative;
      display: grid;
      grid-auto-flow: column;
      grid-auto-columns: 1fr;
      gap: 0;
      padding: 4px;
