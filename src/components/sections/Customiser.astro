    /* Dots */
    .cz-dots { display: flex; gap: 5px; justify-content: center; }
    .cz-spot-frame .cz-dots { position: absolute; left: 0; right: 0; bottom: 8px; z-index: 3; }
    .cz-dot { width: 6px; height: 6px; border-radius: 999px; background: rgba(255,255,255,0.4); transition: all var(--dur) var(--ease-out); }
    .cz-dot.is-on { width: 16px; background: #fff; }
    .cz-star { color: var(--accent); }

    /* ---- iOS 26 Liquid-Glass tab bar (floating, inset from bottom) ---- */
    .cz-tabbar-wrap {
