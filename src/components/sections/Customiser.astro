---
/**
 * Customiser — id="customise".
 *
 * THE interactive playground: a glass control panel drives a live Pippin phone/
 * tablet preview built to look like the REAL Pippin iOS app. Accent · Theme ·
 * Poster size · Shelf style · Navigation all re-tint / re-flow the preview
 * instantly via applyPalette() (from palette.js).
 *
 * The preview uses REAL artwork (Blender Open-Movie posters/backdrops/logos,
 * CC-BY) served from /media/. All colour comes from CSS custom properties set
 * by applyPalette on the `.cz-stage` container — children re-tint live. The
 * only literal colours are the procedural film gradients (fallback behind the
 * images) and unavoidable overlay scrims (black gradients), which are
 * structural, not brand colour.
 *
 * Fidelity references (read-only, in the app repo):
 *   Onboarding/Components/OnboardingStylePhoneMock.swift  (the app's own mock)
 *   Onboarding/Components/OnboardingShelfPreview.swift
 *   RootView.swift (tab bar), DesignSystem/.../MediaCard.swift
 */
import { PRESET_ACCENTS, DEFAULT_ACCENT } from '../../lib/palette.js';
import { sampleFilms } from '../../lib/sampleData.js';

// Serialise the film data the client script needs (keep it lean).
const films = sampleFilms.map((f) => ({
  id: f.id,
  title: f.title,
  year: f.year,
  rating: f.rating,
  genres: f.genres,
  gradTop: f.gradTop,
  gradBottom: f.gradBottom,
  logo: f.logo,
  poster: f.poster,
  backdrop: f.backdrop,
}));
---
<section class="section" id="customise">
  <div class="container">
    <header class="cz-head reveal">
      <p class="eyebrow">Make it yours</p>
      <h2 class="section-title">Your library. Your rules.</h2>
      <p class="section-subtitle">
        Pippin bends to your taste. Pick an accent and every surface re-tints in
        real time; choose a theme, resize posters, morph your shelves, swap tabs
        for a sidebar. Try it right here — this is a live, running slice of the app.
      </p>
    </header>

    <div class="cz-grid reveal" style="--reveal-delay:120ms">
      <!-- ============================== CONTROL PANEL ==================== -->
      <div class="cz-panel glass" role="group" aria-label="Customisation controls">
        <!-- Accent -->
        <div class="cz-ctl">
          <div class="cz-ctl-head">
            <span class="cz-label" id="cz-accent-label">Accent</span>
            <span class="cz-hint">Recolours everything</span>
          </div>
          <div class="cz-accents" role="radiogroup" aria-labelledby="cz-accent-label" id="cz-accents">
            {PRESET_ACCENTS.map((a, i) => (
              <button
                type="button"
                class="cz-swatch"
                role="radio"
                aria-checked={i === 0 ? 'true' : 'false'}
                aria-label={a.name}
                title={a.name}
                data-hex={a.hex}
                style={`--sw:${a.hex}`}
              ><span class="cz-swatch-dot"></span></button>
            ))}
            <label class="cz-swatch cz-swatch-custom" title="Custom colour">
              <span class="cz-swatch-dot cz-custom-dot" aria-hidden="true"></span>
              <input type="color" id="cz-color" value={DEFAULT_ACCENT} aria-label="Custom accent colour" />
            </label>
          </div>
        </div>

        <!-- Theme -->
        <div class="cz-ctl">
          <div class="cz-ctl-head">
            <span class="cz-label" id="cz-theme-label">Theme</span>
          </div>
          <div class="cz-seg" role="radiogroup" aria-labelledby="cz-theme-label" data-group="theme">
            <button type="button" role="radio" aria-checked="false" data-val="system">System</button>
            <button type="button" role="radio" aria-checked="false" data-val="light">Light</button>
            <button type="button" role="radio" aria-checked="true" data-val="dark">Dark</button>
            <button type="button" role="radio" aria-checked="false" data-val="black">True Black</button>
            <span class="cz-seg-thumb" aria-hidden="true"></span>
          </div>
        </div>

        <!-- Poster size -->
        <div class="cz-ctl">
          <div class="cz-ctl-head">
            <span class="cz-label" id="cz-poster-label">Poster size</span>
            <span class="cz-hint">Row shelf</span>
          </div>
          <div class="cz-seg" role="radiogroup" aria-labelledby="cz-poster-label" data-group="poster">
            <button type="button" role="radio" aria-checked="false" data-val="xs">XS</button>
            <button type="button" role="radio" aria-checked="false" data-val="s">S</button>
            <button type="button" role="radio" aria-checked="false" data-val="m">M</button>
            <button type="button" role="radio" aria-checked="true" data-val="l">L</button>
            <button type="button" role="radio" aria-checked="false" data-val="xl">XL</button>
            <span class="cz-seg-thumb" aria-hidden="true"></span>
          </div>
        </div>

        <!-- Shelf style -->
        <div class="cz-ctl">
          <div class="cz-ctl-head">
            <span class="cz-label" id="cz-shelf-label">Top shelf</span>
          </div>
          <div class="cz-seg" role="radiogroup" aria-labelledby="cz-shelf-label" data-group="shelf">
            <button type="button" role="radio" aria-checked="false" data-val="row">Row</button>
            <button type="button" role="radio" aria-checked="false" data-val="spotlight">Spotlight</button>
            <button type="button" role="radio" aria-checked="true" data-val="hero">Hero</button>
            <span class="cz-seg-thumb" aria-hidden="true"></span>
          </div>
        </div>

        <!-- Navigation -->
        <div class="cz-ctl">
          <div class="cz-ctl-head">
            <span class="cz-label" id="cz-layout-label">Navigation</span>
          </div>
          <div class="cz-seg" role="radiogroup" aria-labelledby="cz-layout-label" data-group="layout">
            <button type="button" role="radio" aria-checked="true" data-val="tabs">Tabs</button>
            <button type="button" role="radio" aria-checked="false" data-val="sidebar">Sidebar</button>
            <span class="cz-seg-thumb" aria-hidden="true"></span>
          </div>
        </div>

        <div class="cz-panel-foot">
          <button type="button" class="btn btn-ghost cz-random" id="cz-random">
            <svg viewBox="0 0 24 24" width="17" height="17" fill="none" aria-hidden="true">
              <path d="M16 3h5v5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M4 20 21 3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M21 16v5h-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M15 15l6 6M4 4l5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Surprise me
          </button>
          <p class="cz-panel-note">Nothing here is saved — it's a playground.</p>
        </div>
      </div>

      <!-- ============================== DEVICE PREVIEW =================== -->
      <div class="cz-preview" data-layout="tabs">
        <div class="cz-device">
          <div class="cz-stage" id="cz-stage" data-shelf="hero" data-poster="l">
            <!-- Sidebar (tablet layout) -->
            <nav class="cz-sidebar" aria-hidden="true">
              <div class="cz-sb-brand">
                <span class="cz-sb-dot"></span>
                <span class="cz-sb-brandtxt">Pippin</span>
              </div>
              <ul class="cz-sb-list" id="cz-sidebar-list"></ul>
            </nav>

            <!-- Content column -->
            <div class="cz-content">
              <!-- Status bar -->
              <div class="cz-statusbar" aria-hidden="true">
                <span class="cz-clock">9:41</span>
                <span class="cz-island"></span>
                <span class="cz-status-glyphs">
                  <svg viewBox="0 0 18 12" width="17" height="11" aria-hidden="true">
                    <path d="M9 11.2 1 4.2A11.2 11.2 0 0 1 17 4.2Z" fill="currentColor" opacity="0.9"/>
                  </svg>
                  <svg viewBox="0 0 26 13" width="22" height="11" aria-hidden="true">
                    <rect x="0.5" y="1.5" width="21" height="10" rx="3" fill="none" stroke="currentColor" stroke-opacity="0.5"/>
                    <rect x="2.2" y="3.2" width="15" height="6.6" rx="1.6" fill="currentColor"/>
                    <rect x="23" y="4.5" width="2" height="4" rx="1" fill="currentColor" opacity="0.5"/>
                  </svg>
                </span>
              </div>

              <!-- Nav header (row/spotlight only) -->
              <div class="cz-navhead" id="cz-navhead">
                <span class="cz-navtitle">Home</span>
                <span class="cz-navavatar">
                  <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
                    <circle cx="12" cy="8" r="4" fill="currentColor"/>
                    <path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8" fill="currentColor"/>
                  </svg>
                </span>
              </div>

              <!-- Scroll body -->
              <div class="cz-scroll" id="cz-scroll">
                <!-- top shelf host (swaps between row/spotlight/hero) -->
                <div class="cz-topshelf" id="cz-topshelf"></div>

                <!-- Always-on second shelf below -->
                <div class="cz-shelf">
                  <div class="cz-shelf-head">
                    <span class="cz-shelf-title">Recently Added</span>
                    <span class="cz-shelf-more">See All</span>
                  </div>
                  <div class="cz-rail cz-rail--poster cz-rail--fixed" id="cz-rail2"></div>
                </div>
              </div>

              <!-- Tab bar (portrait layout) — floating Liquid-Glass bar -->
              <nav class="cz-tabbar-wrap" id="cz-tabbar-wrap" aria-hidden="true">
                <div class="cz-tabbar" id="cz-tabbar"></div>
              </nav>
            </div>
          </div>
          <div class="cz-device-glow" aria-hidden="true"></div>
        </div>
      </div>
    </div>
  </div>

  <script
    is:inline
    define:vars={{ films, presets: PRESET_ACCENTS, defaultAccent: DEFAULT_ACCENT }}
  >
    (function () {
      const stage = document.getElementById('cz-stage');
      if (!stage) return;

      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // ---- palette (inlined so no import needed in inline script) ---------
      function hexToRgb(hex) {
        let h = String(hex).trim().replace(/^#/, '');
        if (h.length === 3) h = h.split('').map((c) => c + c).join('');
        const int = parseInt(h, 16);
        return { r: (int >> 16) & 255, g: (int >> 8) & 255, b: int & 255 };
      }
      function clamp01(x) { return x < 0 ? 0 : x > 1 ? 1 : x; }
      function hexToHsb(hex) {
        const { r, g, b } = hexToRgb(hex);
        const rf = r / 255, gf = g / 255, bf = b / 255;
        const max = Math.max(rf, gf, bf), min = Math.min(rf, gf, bf), d = max - min;
        let h = 0;
        if (d !== 0) {
          if (max === rf) h = ((gf - bf) / d) % 6;
          else if (max === gf) h = (bf - rf) / d + 2;
          else h = (rf - gf) / d + 4;
          h /= 6; if (h < 0) h += 1;
        }
        return { h, s: max === 0 ? 0 : d / max, b: max };
      }
      function hsbToCss(h, s, b) {
        h = ((h % 1) + 1) % 1; s = clamp01(s); b = clamp01(b);
        const i = Math.floor(h * 6), f = h * 6 - i;
        const p = b * (1 - s), q = b * (1 - f * s), t = b * (1 - (1 - f) * s);
        let r, g, bl;
        switch (i % 6) {
          case 0: r = b; g = t; bl = p; break;
          case 1: r = q; g = b; bl = p; break;
          case 2: r = p; g = b; bl = t; break;
          case 3: r = p; g = q; bl = b; break;
          case 4: r = t; g = p; bl = b; break;
          default: r = b; g = p; bl = q; break;
        }
        return `rgb(${Math.round(r * 255)}, ${Math.round(g * 255)}, ${Math.round(bl * 255)})`;
      }
      // Choose a legible foreground for the accent (used on the Resume/tint pills).
      function accentForeground(hex) {
        const { r, g, b } = hexToRgb(hex);
        const lum = (0.299 * r + 0.587 * g + 0.114 * b) / 255;
        return lum > 0.62 ? 'rgb(10, 14, 12)' : 'rgb(255, 255, 255)';
      }
      function applyPalette(el, accentHex, theme = 'dark', tint = 1) {
        const { h, s } = hexToHsb(accentHex);
        const t = clamp01(tint);
        const c = hexToRgb(accentHex);
        const emerald = hsbToCss(h, Math.min(s + 0.1, 0.7) * t, 0.1);
        let bg, grouped, secondary, card, sep;
        if (theme === 'light') {
          bg = hsbToCss(h, 0.04 * t, 0.985);
          grouped = hsbToCss(h, 0.055 * t, 0.96);
          secondary = hsbToCss(h, 0.07 * t, 0.935);
          card = hsbToCss(h, 0.022 * t, 1.0);
          sep = hsbToCss(h, 0.1 * t, 0.83);
        } else {
          bg = hsbToCss(h, Math.min(s + 0.05, 0.44) * t, 0.11);
          grouped = hsbToCss(h, Math.min(s + 0.05, 0.44) * t, 0.15);
          secondary = hsbToCss(h, Math.min(s + 0.04, 0.42) * t, 0.22);
          card = hsbToCss(h, Math.min(s + 0.14, 0.66) * t, 0.165);
          sep = hsbToCss(h, 0.2 * t, 0.34);
          if (theme === 'black') {
            bg = '#000000';
            card = hsbToCss(h, Math.min(s + 0.14, 0.66) * t, 0.165 * 0.6);
          }
        }
        const isLight = theme === 'light';
        const map = {
          '--accent': `rgb(${c.r}, ${c.g}, ${c.b})`,
          '--accent-subtle': `rgba(${c.r}, ${c.g}, ${c.b}, 0.15)`,
          '--accent-muted': `rgba(${c.r}, ${c.g}, ${c.b}, 0.28)`,
          '--accent-fg': accentForeground(accentHex),
          '--bg': bg,
          '--bg-grouped': grouped,
          '--bg-secondary': secondary,
          '--card': card,
          '--separator': sep,
          '--label': isLight ? 'rgb(20, 22, 24)' : 'rgb(244, 245, 247)',
          '--label-secondary': isLight ? 'rgba(20, 22, 24, 0.55)' : 'rgba(255, 255, 255, 0.60)',
          '--glass-fill': isLight ? 'rgba(255, 255, 255, 0.62)' : 'rgba(28, 30, 34, 0.52)',
          '--glass-hairline': isLight ? 'rgba(0, 0, 0, 0.08)' : 'rgba(255, 255, 255, 0.14)',
          '--emerald-depths': emerald,
        };
        for (const k in map) el.style.setProperty(k, map[k]);
      }

      // ---- state ----------------------------------------------------------
      const state = {
        accent: defaultAccent,
        theme: 'dark',   // system→dark, light, dark, black
        poster: 'l',
        shelf: 'hero',
        layout: 'tabs',
      };
      // Rail poster widths (px) — the app's intended mock tiers. At L (default)
      // ~2 posters span the phone mock; at XS ~3–4 fit, the rest scroll off the
      // right edge (clipped by the phone frame).
      const POSTER_W = { xs: 64, s: 78, m: 92, l: 112, xl: 132 };

      const preview = document.querySelector('.cz-preview');
      const topshelf = document.getElementById('cz-topshelf');
      const rail2 = document.getElementById('cz-rail2');
      const tabbar = document.getElementById('cz-tabbar');
      const sidebarList = document.getElementById('cz-sidebar-list');
      const navhead = document.getElementById('cz-navhead');

      // ---- icons ----------------------------------------------------------
      const ICON = {
        home: '<path d="M3 10.5 12 3l9 7.5V21a1 1 0 0 1-1 1h-5v-6h-6v6H4a1 1 0 0 1-1-1z"/>',
        movies: '<rect x="3" y="4" width="18" height="16" rx="2"/><path d="M3 9h18M8 4v5M16 4v5M8 20v-5M16 20v-5" fill="none" stroke="currentColor" stroke-width="1.6"/>',
        tv: '<rect x="2.5" y="5" width="19" height="12" rx="2"/><path d="M8 21h8M12 17v4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>',
        downloads: '<path d="M12 3v11m0 0 4-4m-4 4-4-4" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"/><path d="M4 17v2a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-2" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round"/>',
        search: '<circle cx="11" cy="11" r="6.2" fill="none" stroke="currentColor" stroke-width="1.9"/><path d="m16 16 4.5 4.5" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round"/>',
      };
      function svg(name) {
        const solid = name === 'home' || name === 'movies' || name === 'tv';
        return `<svg viewBox="0 0 24 24" width="22" height="22" fill="${solid ? 'currentColor' : 'none'}" aria-hidden="true">${ICON[name]}</svg>`;
      }

      const TABS = [
        { icon: 'home', label: 'Home' },
        { icon: 'movies', label: 'Movies' },
        { icon: 'tv', label: 'TV' },
        { icon: 'downloads', label: 'Downloads' },
      ];
      const SIDEBAR = [
        { icon: 'home', label: 'Home' },
        { icon: 'movies', label: 'Movies' },
        { icon: 'tv', label: 'TV Shows' },
        { icon: 'downloads', label: 'Downloads' },
        { icon: 'search', label: 'Search' },
      ];

      // Metadata line, matching the app: year · genre · ★rating (rating optional).
      function metaLine(f) {
        const parts = [];
        if (f.year) parts.push(String(f.year));
        parts.push(f.genres[0]);
        if (f.rating != null) parts.push(`<span class="cz-star">★</span> ${f.rating.toFixed(1)}`);
        return parts.join(' · ');
      }
      function gradStyle(f) {
        return `background:linear-gradient(150deg, ${f.gradTop}, ${f.gradBottom});`;
      }
      // Clear-logo when present (and good quality), else a clean styled title.
      // `elephants` logo is tiny/low-quality → prefer styled title.
      function hasGoodLogo(f) { return !!f.logo && f.id !== 'elephants'; }
      function logoOrTitle(f, cls) {
        if (hasGoodLogo(f)) return `<img class="${cls} cz-logo-img" src="/media/${f.logo}" alt="${f.title}" loading="lazy" />`;
        return `<span class="${cls} cz-logo-txt">${f.title}</span>`;
      }

      // ---- poster card (real 2:3 poster + optional progress bar) ----------
      function posterCard(f, progress) {
        const bar = progress != null
          ? `<span class="cz-poster-prog"><span class="cz-poster-prog-fill" style="width:${Math.round(clamp01(progress) * 100)}%"></span></span>`
          : '';
        const inner = f.poster
          ? `<img src="/media/${f.poster}" alt="${f.title}" class="cz-poster-img" loading="lazy" />`
          : `<div class="cz-poster-art" style="${gradStyle(f)}"><span class="cz-poster-t">${f.title}</span></div>`;
        return `<div class="cz-poster">${inner}${bar}</div>`;
      }

      // ---- shelf renderers ------------------------------------------------
      // ROW — a section header + a HORIZONTAL poster rail of real 2:3 posters,
      // width driven by the poster-size control. A couple show progress bars.
      function renderRow(host) {
        const items = films.slice(0, 8);
        const prog = [0.62, 0.3, null, 0.85, null, 0.47, null, 0.14];
        host.innerHTML = `
          <div class="cz-shelf cz-shelf--top">
            <div class="cz-shelf-head">
              <span class="cz-shelf-title">Continue Watching</span>
              <span class="cz-shelf-more">See All</span>
            </div>
            <div class="cz-rail cz-rail--poster">
              ${items.map((f, i) => posterCard(f, prog[i % prog.length])).join('')}
            </div>
          </div>`;
      }

      let carousel = { idx: 0, timer: null };
      function renderSpotlight(host) {
        const items = films.slice(0, 5);
        host.innerHTML = `
          <div class="cz-spot">
            <div class="cz-spot-frame">
              ${items.map((f, i) => `
                <div class="cz-spot-slide${i === 0 ? ' is-on' : ''}" data-i="${i}" style="${gradStyle(f)}">
                  ${f.backdrop ? `<img class="cz-spot-bg" src="/media/${f.backdrop}" alt="" loading="lazy" />` : ''}
                  <div class="cz-spot-scrim"></div>
                  <div class="cz-spot-body">
                    ${logoOrTitle(f, 'cz-spot-logo')}
                    <div class="cz-spot-meta">${metaLine(f)}</div>
                  </div>
                </div>`).join('')}
              <div class="cz-dots">${items.map((_, i) => `<span class="cz-dot${i === 0 ? ' is-on' : ''}"></span>`).join('')}</div>
            </div>
          </div>
          <div class="cz-shelf cz-shelf--top">
            <div class="cz-shelf-head">
              <span class="cz-shelf-title">Trending</span>
              <span class="cz-shelf-more">See All</span>
            </div>
            <div class="cz-rail cz-rail--poster">
              ${films.slice(2, 8).map((f, i) => posterCard(f, [0.4, 0.7, null, 0.9, null, 0.33][i % 6])).join('')}
            </div>
          </div>`;
        startCarousel(host, items.length);
      }

      function renderHero(host) {
        const items = films.slice(0, 5);
        host.innerHTML = `
          <div class="cz-hero">
            <div class="cz-hero-art">
              ${items.map((f, i) => `
                <div class="cz-hero-slide${i === 0 ? ' is-on' : ''}" data-i="${i}" style="${gradStyle(f)}">
                  ${f.backdrop ? `<img class="cz-hero-bg" src="/media/${f.backdrop}" alt="" loading="lazy" />` : ''}
                  ${f.backdrop ? `<img class="cz-hero-bg cz-hero-bg--blur" src="/media/${f.backdrop}" alt="" loading="lazy" aria-hidden="true" />` : ''}
                </div>`).join('')}
              <div class="cz-hero-scrim"></div>
              <div class="cz-hero-fade"></div>
            </div>
            <div class="cz-hero-body">
              <div class="cz-hero-caps">
                ${items.map((f, i) => `
                  <div class="cz-hero-cap${i === 0 ? ' is-on' : ''}" data-i="${i}">
                    ${logoOrTitle(f, 'cz-hero-logo')}
                    <div class="cz-hero-meta">${metaLine(f)}</div>
                  </div>`).join('')}
              </div>
              <span class="cz-resume">
                <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true"><path d="M8 5v14l11-7z" fill="currentColor"/></svg>
                Resume
              </span>
              <div class="cz-dots">${items.map((_, i) => `<span class="cz-dot${i === 0 ? ' is-on' : ''}"></span>`).join('')}</div>
            </div>
          </div>
          <div class="cz-shelf cz-shelf--top cz-shelf--hero-peek">
            <div class="cz-shelf-head">
              <span class="cz-shelf-title">Keep Watching</span>
              <span class="cz-shelf-more">See All</span>
            </div>
            <div class="cz-rail cz-rail--poster">
              ${films.slice(1, 7).map((f, i) => posterCard(f, [0.5, 0.8, null, 0.66, null, 0.9][i % 6])).join('')}
            </div>
          </div>`;
        startCarousel(host, items.length);
      }

      function startCarousel(host, count) {
        stopCarousel();
        carousel.idx = 0;
        carousel.count = count;
        carousel.host = host;
        if (reduced || count <= 1) return;
        carousel.timer = setInterval(() => {
          carousel.idx = (carousel.idx + 1) % count;
          setCarousel(host, carousel.idx);
        }, 5000);
      }
      function stopCarousel() {
        if (carousel.timer) { clearInterval(carousel.timer); carousel.timer = null; }
      }
      function setCarousel(host, idx) {
        host.querySelectorAll('[data-i]').forEach((el) => {
          el.classList.toggle('is-on', Number(el.dataset.i) === idx);
        });
        host.querySelectorAll('.cz-dot').forEach((d, i) => d.classList.toggle('is-on', i === idx));
      }

      function renderTopShelf() {
        if (state.shelf === 'row') { stopCarousel(); renderRow(topshelf); }
        else if (state.shelf === 'spotlight') renderSpotlight(topshelf);
        else renderHero(topshelf);
        stage.dataset.shelf = state.shelf;
        // nav header hidden in hero (art bleeds to the top)
        navhead.style.display = state.shelf === 'hero' ? 'none' : '';
      }

      // ---- static rail (second shelf) + chrome ----------------------------
      function renderRail2() {
        rail2.innerHTML = films.slice(2, 8).map((f) => posterCard(f, null)).join('');
      }
      function renderChrome() {
        tabbar.innerHTML = TABS.map((t, i) => `
          <span class="cz-tab${i === 0 ? ' is-on' : ''}">
            ${svg(t.icon)}<span class="cz-tab-lbl">${t.label}</span>
          </span>`).join('');
        sidebarList.innerHTML = SIDEBAR.map((t, i) => `
          <li class="cz-sb-item${i === 0 ? ' is-on' : ''}">
            ${svg(t.icon)}<span class="cz-sb-lbl">${t.label}</span>
          </li>`).join('');
      }

      // ---- apply state ----------------------------------------------------
      function applyPoster() {
        stage.dataset.poster = state.poster;
        stage.style.setProperty('--poster-w', POSTER_W[state.poster] + 'px');
      }
      function applyLayout() {
        preview.dataset.layout = state.layout;
      }
      function retint() {
        applyPalette(stage, state.accent, state.theme, 1);
      }

      // ---- control wiring -------------------------------------------------
      function moveThumb(seg) {
        const btns = [...seg.querySelectorAll('[role="radio"]')];
        const active = seg.querySelector('[aria-checked="true"]');
        const thumb = seg.querySelector('.cz-seg-thumb');
        if (!active || !thumb) return;
        const idx = btns.indexOf(active);
        thumb.style.width = (100 / btns.length) + '%';
        thumb.style.transform = `translateX(${idx * 100}%)`;
      }

      document.querySelectorAll('.cz-seg[data-group]').forEach((seg) => {
        const group = seg.dataset.group;
        const btns = [...seg.querySelectorAll('[role="radio"]')];
        function select(btn, focus) {
          btns.forEach((b) => b.setAttribute('aria-checked', b === btn ? 'true' : 'false'));
          moveThumb(seg);
          const val = btn.dataset.val;
          if (group === 'theme') { state.theme = val === 'system' ? 'dark' : val; retint(); }
          else if (group === 'poster') { state.poster = val; applyPoster(); }
          else if (group === 'shelf') { state.shelf = val; renderTopShelf(); retint(); }
          else if (group === 'layout') { state.layout = val; applyLayout(); }
          if (focus) btn.focus();
        }
        btns.forEach((btn, i) => {
          btn.addEventListener('click', () => select(btn));
          btn.addEventListener('keydown', (e) => {
            if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
              e.preventDefault(); select(btns[(i + 1) % btns.length], true);
            } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
              e.preventDefault(); select(btns[(i - 1 + btns.length) % btns.length], true);
            }
          });
        });
        requestAnimationFrame(() => moveThumb(seg));
      });

      // Accent swatches
      const accentGroup = document.getElementById('cz-accents');
      const swatches = [...accentGroup.querySelectorAll('.cz-swatch[data-hex]')];
      const colorInput = document.getElementById('cz-color');
      function selectAccent(hex, fromSwatch) {
        state.accent = hex;
        retint();
        swatches.forEach((s) => s.setAttribute('aria-checked', s.dataset.hex.toLowerCase() === hex.toLowerCase() ? 'true' : 'false'));
        const isPreset = swatches.some((s) => s.dataset.hex.toLowerCase() === hex.toLowerCase());
        document.querySelector('.cz-swatch-custom').setAttribute('data-active', isPreset ? 'false' : 'true');
        if (fromSwatch) colorInput.value = hex;
      }
      swatches.forEach((s, i) => {
        s.addEventListener('click', () => selectAccent(s.dataset.hex, true));
        s.addEventListener('keydown', (e) => {
          if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
            e.preventDefault(); const n = swatches[(i + 1) % swatches.length]; n.focus(); selectAccent(n.dataset.hex, true);
          } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
            e.preventDefault(); const n = swatches[(i - 1 + swatches.length) % swatches.length]; n.focus(); selectAccent(n.dataset.hex, true);
          }
        });
      });
      colorInput.addEventListener('input', () => {
        swatches.forEach((s) => s.setAttribute('aria-checked', 'false'));
        state.accent = colorInput.value;
        retint();
        document.querySelector('.cz-swatch-custom').setAttribute('data-active', 'true');
      });

      // Randomise
      const RThemes = ['light', 'dark', 'black'];
      const RPoster = ['xs', 's', 'm', 'l', 'xl'];
      const RShelf = ['row', 'spotlight', 'hero'];
      const RLayout = ['tabs', 'sidebar'];
      function pick(a) { return a[Math.floor(Math.random() * a.length)]; }
      document.getElementById('cz-random').addEventListener('click', () => {
        const accent = presets[Math.floor(Math.random() * presets.length)].hex;
        const theme = pick(RThemes), poster = pick(RPoster), shelf = pick(RShelf), layout = pick(RLayout);
        syncSeg('theme', theme);
        syncSeg('poster', poster);
        syncSeg('shelf', shelf);
        syncSeg('layout', layout);
        state.theme = theme; state.poster = poster; state.shelf = shelf; state.layout = layout;
        applyPoster(); renderTopShelf(); applyLayout();
        selectAccent(accent, true);
      });
      function syncSeg(group, val) {
        const seg = document.querySelector(`.cz-seg[data-group="${group}"]`);
        seg.querySelectorAll('[role="radio"]').forEach((b) =>
          b.setAttribute('aria-checked', b.dataset.val === val ? 'true' : 'false'));
        moveThumb(seg);
      }

      // Pause carousel when preview off-screen (perf).
      if ('IntersectionObserver' in window) {
        new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              if (!reduced && (state.shelf === 'hero' || state.shelf === 'spotlight') && !carousel.timer && carousel.count > 1) {
                carousel.timer = setInterval(() => {
                  carousel.idx = (carousel.idx + 1) % carousel.count;
                  setCarousel(carousel.host || topshelf, carousel.idx);
                }, 5000);
              }
            } else {
              stopCarousel();
            }
          });
        }, { threshold: 0.15 }).observe(preview);
      }

      // ---- initial render -------------------------------------------------
      renderChrome();
      renderRail2();
      applyPoster();
      applyLayout();
      renderTopShelf();
      retint();
    })();
  </script>

  <!-- The interactive preview is built at runtime via innerHTML, so its nodes
       carry no Astro scope attribute. All selectors here are uniquely cz-*-prefixed,
       so the block is marked global to reach both the build-time controls and the
       JS-injected preview content. -->
  <style is:global>
    /* ================================================================== */
    /*  Layout: heading + two-column control/preview                       */
    /* ================================================================== */
    .cz-head { max-width: 62ch; margin-bottom: var(--space-7); }

    .cz-grid {
      display: grid;
      grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
      gap: clamp(var(--space-5), 4vw, var(--space-8));
      align-items: start;
    }
    @media (max-width: 900px) {
      .cz-grid { grid-template-columns: 1fr; }
    }

    /* ================================================================== */
    /*  Control panel                                                      */
    /* ================================================================== */
    .cz-panel {
      padding: clamp(var(--space-4), 3vw, var(--space-6));
      display: flex;
      flex-direction: column;
      gap: var(--space-5);
      position: sticky;
      top: calc(var(--nav-height) + var(--space-4));
    }
    @media (max-width: 900px) { .cz-panel { position: static; } }

    .cz-ctl { display: flex; flex-direction: column; gap: var(--space-3); }
    .cz-ctl-head { display: flex; align-items: baseline; justify-content: space-between; gap: var(--space-3); }
    .cz-label { font-family: var(--font-display); font-weight: 600; font-size: 1.0625rem; color: var(--label); }
    .cz-hint { font-size: 0.75rem; color: var(--label-tertiary); }

    /* Accent swatches */
    .cz-accents { display: flex; flex-wrap: wrap; gap: var(--space-3); }
    .cz-swatch {
      position: relative;
      width: 34px; height: 34px;
      border-radius: var(--radius-pill);
      border: 0; padding: 0; cursor: pointer;
      display: grid; place-items: center;
      background: transparent;
      transition: transform var(--dur-fast) var(--ease-spring);
    }
    .cz-swatch:hover { transform: scale(1.12); }
    .cz-swatch:active { transform: scale(0.96); }
    .cz-swatch-dot {
      width: 26px; height: 26px; border-radius: var(--radius-pill);
      background: var(--sw);
      box-shadow: 0 2px 8px rgba(0,0,0,0.35), inset 0 0 0 1px rgba(255,255,255,0.14);
      transition: box-shadow var(--dur-fast) var(--ease-out);
    }
    .cz-swatch::before {
      content: ''; position: absolute; inset: -3px;
      border-radius: var(--radius-pill);
      border: 2px solid var(--sw, var(--accent));
      opacity: 0; transform: scale(0.8);
      transition: opacity var(--dur-fast) var(--ease-out), transform var(--dur-fast) var(--ease-spring);
    }
    .cz-swatch[aria-checked="true"]::before { opacity: 1; transform: scale(1); }
    .cz-swatch[aria-checked="true"] .cz-swatch-dot { box-shadow: 0 2px 12px rgba(0,0,0,0.4), inset 0 0 0 1px rgba(255,255,255,0.22); }

    .cz-swatch-custom { overflow: hidden; }
    .cz-custom-dot {
      background:
        conic-gradient(from 0deg,
