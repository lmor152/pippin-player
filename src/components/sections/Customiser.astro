      opacity: 0; transition: opacity 0.6s var(--ease-in-out);
    }
    .cz-hero-cap.is-on { opacity: 1; }
    .cz-hero-logo.cz-logo-img { max-width: 66%; max-height: 50px; object-fit: contain; filter: drop-shadow(0 2px 8px rgba(0,0,0,0.7)); }
    .cz-hero-logo.cz-logo-txt { font-family: var(--font-display); font-weight: 800; font-size: 24px; color: #fff; text-shadow: 0 2px 10px rgba(0,0,0,0.7); }
    .cz-hero-meta { font-size: 11px; color: rgba(255,255,255,0.9); font-weight: 600; text-shadow: 0 1px 4px rgba(0,0,0,0.6); }
