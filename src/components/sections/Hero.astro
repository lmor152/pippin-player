<script>
  // Pointer parallax for the device stage (desktop / fine pointer only).
  (() => {
    const reduce = window.matchMedia(
      '(prefers-reduced-motion: reduce)'
    ).matches;
    const finePointer = window.matchMedia('(pointer: fine)').matches;
    if (reduce || !finePointer) return;

    const stage = document.querySelector('.hero-stage');
    const inner = stage?.querySelector('[data-parallax]');
    if (!stage || !inner) return;

    const layers = Array.from(
      inner.querySelectorAll('[data-depth]')
    ) as HTMLElement[];

    let raf = 0;
    let tx = 0;
    let ty = 0;
    let cx = 0;
    let cy = 0;

    const apply = () => {
      cx += (tx - cx) * 0.08;
      cy += (ty - cy) * 0.08;
      for (const el of layers) {
        const d = parseFloat(el.dataset.depth || '0.5');
        // `translate` is independent of the CSS float `transform`, so the two
        // compose without fighting each other.
        el.style.translate = `${cx * d * 18}px ${cy * d * 14}px`;
      }
      if (Math.abs(tx - cx) > 0.001 || Math.abs(ty - cy) > 0.001) {
        raf = requestAnimationFrame(apply);
      } else {
        raf = 0;
      }
    };

    const onMove = (e: PointerEvent) => {
      const r = stage.getBoundingClientRect();
      tx = (e.clientX - (r.left + r.width / 2)) / r.width;
      ty = (e.clientY - (r.top + r.height / 2)) / r.height;
      if (!raf) raf = requestAnimationFrame(apply);
    };

    const onLeave = () => {
      tx = 0;
      ty = 0;
      if (!raf) raf = requestAnimationFrame(apply);
    };

    stage.addEventListener('pointermove', onMove);
    stage.addEventListener('pointerleave', onLeave);
  })();
</script>
