    font-size: 0.56rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.4);
  }
  .scrub-thumb-badge svg {
