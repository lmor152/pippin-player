</style>

<script>
  (() => {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)');

    const fmt = (secs) => {
      secs = Math.max(0, Math.round(secs));
      const m = Math.floor(secs / 60);
      const s = secs % 60;
      return `${m}:${String(s).padStart(2, '0')}`;
    };

    /* ────────────────────────────────────────────────────────────
       Player stage — app-faithful scrubber with generated-preview bubble
       ──────────────────────────────────────────────────────────── */
    (() => {
      const stage = document.querySelector('#player .player-stage');
      if (!stage) return;

      const scrubber = stage.querySelector('[data-role="scrubber"]');
      const fill = stage.querySelector('[data-role="fill"]');
      const knob = stage.querySelector('[data-role="knob"]');
      const thumb = stage.querySelector('[data-role="thumb"]');
      const frameA = stage.querySelector('[data-role="frame-a"]');
      const frameB = stage.querySelector('[data-role="frame-b"]');
      const thumbTime = stage.querySelector('[data-role="thumb-time"]');
      const curEl = stage.querySelector('[data-role="cur"]');
      const remEl = stage.querySelector('[data-role="rem"]');
      const bigplay = stage.querySelector('[data-role="bigplay"]');
      const playbtn = stage.querySelector('[data-role="playbtn"]');
      if (!scrubber || !fill || !knob) return;

      const TOTAL = 42 * 60 + 19; // 42:19 in seconds

      let progress = 0.28;   // 0..1
      let playing = !reduce.matches;
      let dragging = false;
      let lastTs = 0;
      let showingA = true;
      let lastBucket = -1;
      let spinnerTimer = 0;

      const paintPlay = () => {
        [bigplay, playbtn].forEach((btn) => {
          if (!btn) return;
          const p = btn.querySelector('[data-icon="play"]');
          const q = btn.querySelector('[data-icon="pause"]');
          if (p) p.hidden = playing;
          if (q) q.hidden = !playing;
        });
      };

      const render = () => {
        const pct = (progress * 100).toFixed(3) + '%';
        fill.style.width = pct;
        knob.style.left = pct;
        if (curEl) curEl.textContent = fmt(progress * TOTAL);
        if (remEl) remEl.textContent = '-' + fmt((1 - progress) * TOTAL);
      };

      const setProgress = (p) => {
        progress = Math.min(1, Math.max(0, p));
        render();
        syncAria();
      };

      // Swap the "generated frame" by nudging the background-position of the
      // hidden layer to a bucket-derived region of the real backdrop, then
      // cross-fading it in — reads as a distinct frame sharpening into place.
      const showFrame = (ratio) => {
        if (!frameA || !frameB) return;
        const bucket = Math.floor(ratio * 24); // ~10s buckets across the demo
        if (bucket === lastBucket) return;
        lastBucket = bucket;
        // Pseudo-random-but-stable pan across the source image per bucket.
        const px = 10 + ((bucket * 37) % 80);
        const py = 20 + ((bucket * 53) % 60);
        const next = showingA ? frameB : frameA;
        const cur = showingA ? frameA : frameB;
        next.style.backgroundPosition = `${px}% ${py}%`;
        next.classList.add('is-active');
        cur.classList.remove('is-active');
        showingA = !showingA;

        // Brief loading spinner, as the real headless engine renders the frame.
        if (!reduce.matches) {
          thumb.classList.add('is-loading');
          clearTimeout(spinnerTimer);
          spinnerTimer = window.setTimeout(() => thumb.classList.remove('is-loading'), 240);
        }
      };

      const showThumbAt = (clientX) => {
        const rect = scrubber.getBoundingClientRect();
        let ratio = (clientX - rect.left) / rect.width;
        ratio = Math.min(1, Math.max(0, ratio));
        thumb.style.left = (ratio * 100).toFixed(2) + '%';
        if (thumbTime) thumbTime.textContent = fmt(ratio * TOTAL);
        showFrame(ratio);
        thumb.classList.add('is-visible');
        return ratio;
      };
      const hideThumb = () => {
        if (reduce.matches) return; // keep static-but-present
        thumb && thumb.classList.remove('is-visible');
      };

      scrubber.addEventListener('pointermove', (e) => {
        const ratio = showThumbAt(e.clientX);
        if (dragging) setProgress(ratio);
      });
      scrubber.addEventListener('pointerleave', () => {
        if (!dragging) hideThumb();
      });
      scrubber.addEventListener('pointerdown', (e) => {
        dragging = true;
        scrubber.setPointerCapture?.(e.pointerId);
        setProgress(showThumbAt(e.clientX));
      });
      const endDrag = (e) => {
        if (!dragging) return;
        dragging = false;
        scrubber.releasePointerCapture?.(e.pointerId);
        hideThumb();
      };
      scrubber.addEventListener('pointerup', endDrag);
      scrubber.addEventListener('pointercancel', endDrag);

      // Keyboard access on the scrubber
      scrubber.setAttribute('tabindex', '0');
      scrubber.setAttribute('role', 'slider');
      scrubber.setAttribute('aria-label', 'Seek');
      scrubber.setAttribute('aria-valuemin', '0');
      scrubber.setAttribute('aria-valuemax', '100');
      function syncAria() {
        scrubber.setAttribute('aria-valuenow', String(Math.round(progress * 100)));
        scrubber.setAttribute('aria-valuetext', fmt(progress * TOTAL) + ' of ' + fmt(TOTAL));
      }
      scrubber.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowRight') { setProgress(progress + 0.02); e.preventDefault(); }
        else if (e.key === 'ArrowLeft') { setProgress(progress - 0.02); e.preventDefault(); }
      });

      const toggle = () => { playing = !playing; paintPlay(); };
      bigplay?.addEventListener('click', toggle);
      playbtn?.addEventListener('click', toggle);

      const tick = (ts) => {
        if (playing && !dragging && !reduce.matches) {
          if (lastTs) {
            const dt = (ts - lastTs) / 1000;
            progress += dt / TOTAL;
            if (progress >= 1) progress = 0;
            render();
            syncAria();
          }
          lastTs = ts;
        } else {
          lastTs = ts;
        }
        requestAnimationFrame(tick);
      };

      render();
      syncAria();
      paintPlay();
      if (reduce.matches) {
        // Static-but-present: show the bubble parked near the playhead.
        thumb.classList.add('is-visible');
        thumb.style.left = (progress * 100).toFixed(2) + '%';
        if (thumbTime) thumbTime.textContent = fmt(progress * TOTAL);
        showFrame(progress);
      } else {
        requestAnimationFrame(tick);
      }

      reduce.addEventListener?.('change', (e) => {
        if (e.matches) { playing = false; paintPlay(); }
      });
    })();

    /* ────────────────────────────────────────────────────────────
       Standalone generated-thumbnail visual — gentle auto-scrub loop
       ──────────────────────────────────────────────────────────── */
    (() => {
      const viz = document.querySelector('#player .thumb-visual');
      if (!viz) return;
      const preview = viz.querySelector('[data-role="viz-thumb"]');
      const fA = viz.querySelector('[data-role="viz-frame-a"]');
      const fB = viz.querySelector('[data-role="viz-frame-b"]');
      const fill = viz.querySelector('[data-role="viz-fill"]');
      const knob = viz.querySelector('[data-role="viz-knob"]');
      const timeEl = viz.querySelector('[data-role="viz-time"]');
      if (!preview || !fA || !fB || !fill || !knob) return;

      const TOTAL = 42 * 60 + 19;
      let showingA = true;
      let lastBucket = -1;
      let spinnerTimer = 0;

      const place = (ratio) => {
        const pct = (ratio * 100).toFixed(2) + '%';
        fill.style.width = pct;
        knob.style.left = pct;
        if (timeEl) timeEl.textContent = fmt(ratio * TOTAL);
        const bucket = Math.floor(ratio * 24);
        if (bucket !== lastBucket) {
          lastBucket = bucket;
          const px = 10 + ((bucket * 37) % 80);
          const py = 20 + ((bucket * 53) % 60);
          const next = showingA ? fB : fA;
          const cur = showingA ? fA : fB;
          next.style.backgroundPosition = `${px}% ${py}%`;
          next.classList.add('is-active');
          cur.classList.remove('is-active');
          showingA = !showingA;
          if (!reduce.matches) {
            preview.classList.add('is-loading');
            clearTimeout(spinnerTimer);
            spinnerTimer = window.setTimeout(() => preview.classList.remove('is-loading'), 260);
          }
        }
      };

      if (reduce.matches) {
        place(0.5);
        return;
      }

      // Ease back and forth across the bar so the preview keeps updating.
      let t = 0;
      const loop = () => {
        t += 0.006;
        const ratio = 0.5 + 0.42 * Math.sin(t);
        place(ratio);
        requestAnimationFrame(loop);
      };
      place(0.5);
      requestAnimationFrame(loop);
    })();
  })();
</script>
