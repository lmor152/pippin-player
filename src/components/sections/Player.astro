  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* ── Capability grid ───────────────────────────────────────── */
  .cap-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 17rem), 1fr));
