---
/**
 * Player — id="player". Owned by the Player section agent.
 *
 * Sells Pippin's standout MPVKit-based player:
 *   1. A realistic player UI mock centrepiece with app-faithful scrubbing
 *      (accent-filled track, pill handle, intro/credits ticks, 160×90 preview
 *      bubble that follows the playhead and swaps frames as you scrub).
 *   2. A stand-out "generated thumbnails" beat — Pippin makes its own scrub
 *      previews on-device via a headless MPV engine, so instant thumbnail
 *      scrubbing works even when the server has no Trickplay / BIF.
 *   3. A supporting capability grid + an auto-scrolling codec/format "wall".
 */

import { sampleFilms } from '../../lib/sampleData.js';

// Player still: a real backdrop from the demo library (1280×720), with the
// matching clear-logo used as the "now playing" label.
const feature = sampleFilms.find((f) => f.id === 'tos') ?? sampleFilms[0];
const backdrop = `/media/${feature.backdrop}`;
const logo = feature.logo ? `/media/${feature.logo}` : null;

// Supporting capability cards — each with an inline-SVG icon key.
const capabilities = [
  {
    icon: 'film',
    title: 'Plays anything',
    body: 'HEVC / H.265, H.264, AV1, VP9 and MPEG-2 — inside MKV, MP4, MOV, TS or full ISO / BDMV. If it exists in your library, it plays.',
  },
  {
    icon: 'hdr',
    title: 'HDR done right',
    body: 'HDR10, HDR10+, Dolby Vision and HLG, with proper tone-mapping so highlights and shadows land exactly as the colourist intended.',
  },
  {
    icon: 'audio',
    title: 'Lossless audio & passthrough',
    body: 'Dolby Atmos, Dolby Digital+, DTS-HD and TrueHD. Multi-channel bitstreaming straight to your receiver, untouched.',
  },
  {
    icon: 'subtitles',
    title: 'Subtitles that look right',
    body: 'PGS and VOBSUB image subs, SRT, and full ASS / SSA styling. Load external subs or pull them from OpenSubtitles.',
  },
  {
    icon: 'precision',
    title: 'Precision playback',
    body: 'Frame-accurate seeking, thumbnail scrubbing, adjustable playback speed and per-title audio / subtitle selection.',
  },
  {
    icon: 'resume',
    title: 'Never lose your place',
    body: 'Continue Watching, Up Next, and skip-intro / skip-credits driven straight from chapter markers.',
  },
  {
    icon: 'offline',
    title: 'Watch offline',
    body: 'Download any title to your device and play it back on the very same engine — no compromise on the plane or the train.',
  },
];

// The "generated thumbnails" story — three truthful points from the real
// GeneratedThumbnailProvider / MPVHeadlessThumbnailEngine implementation.
const thumbPoints = [
  {
    icon: 'engine',
    title: 'A headless MPV engine',
    body: 'A second, silent player seeks to keyframes and renders frames on the fly — the moment you touch the bar.',
  },
  {
    icon: 'cache',
    title: 'Cached in 10-second buckets',
    body: 'Every preview is disk-cached, so scrubbing back across the same region is instant the second time.',
  },
  {
    icon: 'fallback',
    title: 'Never blanks out',
    body: 'It falls back gracefully — nearest cached frame, then the poster — for any format the player can decode, online or off.',
  },
];

// Format wall chips — hammered home twice for a seamless CSS marquee loop.
const formatChips = [
  'HEVC', 'H.264', 'AV1', 'VP9', 'MPEG-2', 'Dolby Vision', 'HDR10+', 'HDR10',
  'HLG', 'Dolby Atmos', 'DD+', 'DTS-HD', 'TrueHD', 'MKV', 'MP4', 'MOV', 'TS',
  'ISO', 'BDMV', 'PGS', 'VOBSUB', 'SRT', 'ASS / SSA', 'OpenSubtitles',
];
---

<section class="section player" id="player">
  <div class="container">
    <!-- ── Headline ─────────────────────────────────────────────── -->
    <header class="player-head reveal">
      <p class="eyebrow">The player</p>
      <h2 class="section-title">A player that plays it all.</h2>
      <p class="section-subtitle">
        Pippin's player is built on the MPVKit engine with hardware-accelerated
        decode — for flawless playback of anything in your library, wrapped in
        pro-grade controls. It plays everything Infuse can, and then some.
      </p>
    </header>

    <!-- ── Centrepiece: player UI mock ──────────────────────────── -->
    <figure
      class="player-stage reveal"
      style="--reveal-delay:100ms"
      aria-label="Pippin video player interface, playing a film with an on-screen scrubber, thumbnail preview and control bar."
    >
      <div class="stage-media">
        <img
          class="stage-backdrop"
          src={backdrop}
          alt={`Still frame from the film ${feature.title} playing in Pippin.`}
          width="1280"
          height="720"
          loading="lazy"
          decoding="async"
        />
        <div class="stage-scrim" aria-hidden="true"></div>

        <!-- Title / episode label (top-left) -->
        <div class="stage-title" aria-hidden="true">
          <span class="stage-title-eyebrow">Now playing</span>
          {logo ? (
            <img class="stage-title-logo" src={logo} alt="" width="220" height="66" />
          ) : (
            <span class="stage-title-main">{feature.title}</span>
          )}
          <span class="stage-title-sub">{feature.year} · {feature.genres.join(', ')} · 4K Dolby Vision</span>
        </div>

        <!-- Centre play affordance -->
        <button
          type="button"
          class="stage-bigplay"
          data-role="bigplay"
          aria-label="Play or pause the demo"
        >
          <svg data-icon="play" viewBox="0 0 24 24" width="30" height="30" aria-hidden="true">
            <path d="M8 5v14l11-7z" fill="currentColor" />
          </svg>
          <svg data-icon="pause" viewBox="0 0 24 24" width="30" height="30" aria-hidden="true" hidden>
            <path d="M7 5h3v14H7zM14 5h3v14h-3z" fill="currentColor" />
          </svg>
        </button>

        <!-- Control overlay -->
        <div class="stage-controls">
          <!-- Thumbnail preview bubble (160×90, generated-on-device badge) -->
          <div class="scrub-thumb" data-role="thumb" aria-hidden="true">
            <span class="scrub-thumb-frame scrub-thumb-frame--a is-active" data-role="frame-a" style={`background-image:url('${backdrop}')`}></span>
            <span class="scrub-thumb-frame scrub-thumb-frame--b" data-role="frame-b" style={`background-image:url('${backdrop}')`}></span>
            <span class="scrub-thumb-badge">
              <svg viewBox="0 0 24 24" width="11" height="11" aria-hidden="true"><path d="M12 2 3 7v6c0 5 3.8 8.4 9 9 5.2-.6 9-4 9-9V7l-9-5Zm-1.2 13.4L7 11.6l1.4-1.4 2.4 2.4 4.8-4.8L17 9.2l-6.2 6.2Z" fill="currentColor"/></svg>
              Generated on device
            </span>
            <span class="scrub-thumb-spinner" data-role="thumb-spinner" aria-hidden="true"></span>
            <span class="scrub-thumb-time" data-role="thumb-time">0:00</span>
          </div>

          <!-- Scrubber -->
          <div class="scrubber" data-role="scrubber">
            <div class="scrubber-track">
              <div class="scrubber-fill" data-role="fill"></div>
              <!-- Intro / credits marker ticks -->
              <span class="scrubber-tick" style="left:8%"  data-label="Intro"></span>
              <span class="scrubber-tick" style="left:88%" data-label="Credits"></span>
            </div>
            <span class="scrubber-knob" data-role="knob"></span>
          </div>

          <!-- Timecodes under the bar: current left, -remaining right -->
          <div class="scrubber-times" aria-hidden="true">
            <span data-role="cur">0:00</span>
            <span data-role="rem">-42:19</span>
          </div>

          <!-- Control row -->
          <div class="control-row">
            <div class="control-cluster control-cluster--left">
              <button type="button" class="ctl ctl--play" data-role="playbtn" aria-label="Play or pause">
                <svg data-icon="play" viewBox="0 0 24 24" width="22" height="22" aria-hidden="true"><path d="M8 5v14l11-7z" fill="currentColor"/></svg>
                <svg data-icon="pause" viewBox="0 0 24 24" width="22" height="22" aria-hidden="true" hidden><path d="M7 5h3v14H7zM14 5h3v14h-3z" fill="currentColor"/></svg>
              </button>
            </div>

            <div class="control-cluster control-cluster--right">
              <button type="button" class="ctl" aria-label="Audio track">
                <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path d="M12 3a1 1 0 0 0-.7.29L7.6 7H4a1 1 0 0 0-1 1v8a1 1 0 0 0 1 1h3.6l3.7 3.71A1 1 0 0 0 13 20V4a1 1 0 0 0-1-1Zm4.5 3.5a1 1 0 0 0-1.32 1.5 5 5 0 0 1 0 7 1 1 0 1 0 1.32 1.5 7 7 0 0 0 0-10Zm2.83-2.83a1 1 0 0 0-1.33 1.5 9 9 0 0 1 0 12.66 1 1 0 0 0 1.33 1.5 11 11 0 0 0 0-15.66Z" fill="currentColor"/></svg>
              </button>
              <button type="button" class="ctl" aria-label="Subtitles">
                <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path d="M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Zm2 8h5v2H6v-2Zm0-4h8v2H6V8Zm7 4h5v2h-5v-2Zm3-4h2v2h-2V8Z" fill="currentColor"/></svg>
              </button>
              <button type="button" class="ctl ctl--label" aria-label="Playback speed">
                <span>1×</span>
              </button>
              <button type="button" class="ctl" aria-label="Picture in Picture">
                <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path d="M21 3H3a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h18a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2Zm0 16H3V5h18v14Zm-2-8h-8v5h8v-5Z" fill="currentColor"/></svg>
              </button>
              <button type="button" class="ctl" aria-label="AirPlay">
                <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path d="M12 15 6 22h12l-6-7Z" fill="currentColor"/><path d="M4 4h16a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-3v-2h3V6H4v9h3v2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Z" fill="currentColor"/></svg>
              </button>
            </div>
          </div>
        </div>
      </div>

      <figcaption class="stage-hint reveal">
        Drag the scrubber — the preview above is generated on the fly, no server trickplay required.
      </figcaption>
    </figure>

    <!-- ── Stand-out beat: self-generated scrub thumbnails ──────── -->
    <div class="thumb-feature reveal" style="--reveal-delay:80ms">
      <div class="thumb-feature-copy">
        <p class="eyebrow">The trick no one else does</p>
        <h3 class="thumb-feature-title">Scrub previews, generated on&nbsp;device.</h3>
        <p class="thumb-feature-lead">
          Most players can only show scrub thumbnails if your server has already
          built <strong>Trickplay</strong> or <strong>BIF</strong> sprites for
          the file — miss those, and the preview goes blank. Pippin doesn't wait
          on the server. It makes the frames itself, on your device, in real
          time — so you get instant thumbnail scrubbing on <em>anything</em>,
          even sources with no trickplay at all.
        </p>

        <ul class="thumb-points" role="list">
          {thumbPoints.map((p) => (
            <li class="thumb-point">
              <span class="thumb-point-icon" aria-hidden="true">
                {p.icon === 'engine' && (
                  <svg viewBox="0 0 24 24" width="22" height="22"><path d="M12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8Zm0 6a2 2 0 1 1 0-4 2 2 0 0 1 0 4Zm9-2a7 7 0 0 0-.1-1.2l2-1.5-2-3.5-2.3 1a7 7 0 0 0-2-1.2L16.2 2h-4l-.4 2.4a7 7 0 0 0-2 1.2l-2.3-1-2 3.5 2 1.5A7 7 0 0 0 3.4 12a7 7 0 0 0 .1 1.2l-2 1.5 2 3.5 2.3-1a7 7 0 0 0 2 1.2L7.8 22h4l.4-2.4a7 7 0 0 0 2-1.2l2.3 1 2-3.5-2-1.5c.1-.4.1-.8.1-1.2Z" fill="currentColor"/></svg>
                )}
                {p.icon === 'cache' && (
                  <svg viewBox="0 0 24 24" width="22" height="22"><path d="M12 3c-4.4 0-8 1.6-8 3.6v10.8C4 19.4 7.6 21 12 21s8-1.6 8-3.6V6.6C20 4.6 16.4 3 12 3Zm6 14.4c0 .7-2.4 1.8-6 1.8s-6-1.1-6-1.8V15c1.5.9 3.7 1.4 6 1.4s4.5-.5 6-1.4v2.4Zm0-4.8c0 .7-2.4 1.8-6 1.8s-6-1.1-6-1.8v-2.2c1.5.9 3.7 1.4 6 1.4s4.5-.5 6-1.4v2.2ZM12 8.4c-3.6 0-6-1.1-6-1.8S8.4 5 12 5s6 1.1 6 1.6-2.4 1.8-6 1.8Z" fill="currentColor"/></svg>
                )}
                {p.icon === 'fallback' && (
                  <svg viewBox="0 0 24 24" width="22" height="22"><path d="M12 5V2L8 6l4 4V7a5 5 0 1 1-5 5H5a7 7 0 1 0 7-7Z" fill="currentColor"/></svg>
                )}
              </span>
              <div>
                <h4 class="thumb-point-title">{p.title}</h4>
                <p class="thumb-point-body">{p.body}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <!-- Standalone visual: a scrub bubble over a mini timeline -->
      <div class="thumb-visual glass" aria-hidden="true">
        <div class="thumb-visual-preview" data-role="viz-thumb">
          <span class="thumb-visual-frame is-active" data-role="viz-frame-a" style={`background-image:url('${backdrop}')`}></span>
          <span class="thumb-visual-frame" data-role="viz-frame-b" style={`background-image:url('${backdrop}')`}></span>
          <span class="thumb-visual-badge">
            <svg viewBox="0 0 24 24" width="12" height="12" aria-hidden="true"><path d="M12 2 3 7v6c0 5 3.8 8.4 9 9 5.2-.6 9-4 9-9V7l-9-5Zm-1.2 13.4L7 11.6l1.4-1.4 2.4 2.4 4.8-4.8L17 9.2l-6.2 6.2Z" fill="currentColor"/></svg>
            Generated on device
          </span>
          <span class="thumb-visual-spinner" data-role="viz-spinner"></span>
          <span class="thumb-visual-time" data-role="viz-time">12:04</span>
        </div>
        <div class="thumb-visual-bar">
          <div class="thumb-visual-track">
            <div class="thumb-visual-fill" data-role="viz-fill"></div>
            <span class="thumb-visual-tick" style="left:8%"></span>
            <span class="thumb-visual-tick" style="left:88%"></span>
          </div>
          <span class="thumb-visual-knob" data-role="viz-knob"></span>
        </div>
        <p class="thumb-visual-caption">No BIF. No Trickplay. No problem.</p>
      </div>
    </div>

    <!-- ── Supporting capability grid ───────────────────────────── -->
    <ul class="cap-grid" role="list">
      {capabilities.map((cap, i) => (
        <li class="cap-card glass reveal" style={`--reveal-delay:${i * 60}ms`}>
          <span class="cap-icon" aria-hidden="true">
            {cap.icon === 'film' && (
              <svg viewBox="0 0 24 24" width="24" height="24"><path d="M4 3h16a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2Zm0 2v3h3V5H4Zm5 0v3h6V5H9Zm8 0v3h3V5h-3ZM4 10v4h3v-4H4Zm5 0v9h6v-9H9Zm8 0v4h3v-4h-3ZM4 16v3h3v-3H4Zm13 0v3h3v-3h-3Z" fill="currentColor"/></svg>
            )}
            {cap.icon === 'hdr' && (
              <svg viewBox="0 0 24 24" width="24" height="24"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm0 2v16a8 8 0 0 1 0-16Z" fill="currentColor"/></svg>
            )}
            {cap.icon === 'audio' && (
              <svg viewBox="0 0 24 24" width="24" height="24"><path d="M4 9h3l4-4v14l-4-4H4V9Zm11-1a1 1 0 0 1 1.7-.71 5 5 0 0 1 0 7.42A1 1 0 1 1 15 13.3a3 3 0 0 0 0-2.6A1 1 0 0 1 15 8Zm2.8-2.8a1 1 0 0 1 1.42 0 9 9 0 0 1 0 13.6 1 1 0 0 1-1.42-1.42 7 7 0 0 0 0-10.76 1 1 0 0 1 0-1.42Z" fill="currentColor"/></svg>
            )}
            {cap.icon === 'subtitles' && (
              <svg viewBox="0 0 24 24" width="24" height="24"><path d="M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Zm2 8h6v2H6v-2Zm8 0h4v2h-4v-2ZM6 8h4v2H6V8Zm6 0h6v2h-6V8Z" fill="currentColor"/></svg>
            )}
            {cap.icon === 'precision' && (
              <svg viewBox="0 0 24 24" width="24" height="24"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm0 4v6l4 2" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            )}
            {cap.icon === 'resume' && (
              <svg viewBox="0 0 24 24" width="24" height="24"><path d="M12 4a8 8 0 1 1-7.6 5.5 1 1 0 0 1 1.9.66A6 6 0 1 0 12 6v2l-3.5-3L12 1v3Z" fill="currentColor"/></svg>
            )}
            {cap.icon === 'offline' && (
              <svg viewBox="0 0 24 24" width="24" height="24"><path d="M12 3a1 1 0 0 1 1 1v9.6l2.3-2.3a1 1 0 0 1 1.4 1.4l-4 4a1 1 0 0 1-1.4 0l-4-4a1 1 0 0 1 1.4-1.4L11 13.6V4a1 1 0 0 1 1-1ZM5 19h14a1 1 0 0 1 0 2H5a1 1 0 0 1 0-2Z" fill="currentColor"/></svg>
            )}
          </span>
          <h3 class="cap-title">{cap.title}</h3>
          <p class="cap-body">{cap.body}</p>
        </li>
      ))}
    </ul>

    <!-- ── Format wall (auto-scroll marquee) ────────────────────── -->
    <div class="format-wall reveal" style="--reveal-delay:120ms" aria-hidden="true">
      <div class="format-track">
        {formatChips.map((c) => <span class="format-chip">{c}</span>)}
        {formatChips.map((c) => <span class="format-chip">{c}</span>)}
      </div>
    </div>
    <p class="format-caption reveal">
      HEVC, AV1, VP9, Dolby Vision, HDR10+, Atmos, DTS-HD, TrueHD, MKV, ISO,
      PGS, ASS and more — Pippin plays it all.
    </p>
  </div>
</section>

<style>
  .player {
    overflow: clip;
  }

  .player-head {
    max-width: 42rem;
  }

  /* ── Centrepiece stage ─────────────────────────────────────── */
  .player-stage {
    margin: var(--space-8) 0 var(--space-9);
  }

  .stage-media {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--glass-border);
    box-shadow: var(--shadow-lg), var(--shadow-glow);
    background-color: var(--emerald-depths);
  }

  .stage-backdrop {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .stage-scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to top, rgba(0, 0, 0, 0.78) 0%, rgba(0, 0, 0, 0.15) 42%, rgba(0, 0, 0, 0) 62%),
      linear-gradient(to bottom, rgba(0, 0, 0, 0.55) 0%, rgba(0, 0, 0, 0) 35%);
  }

  /* Title / episode label */
  .stage-title {
    position: absolute;
    top: clamp(1rem, 3vw, 2rem);
    left: clamp(1rem, 3vw, 2rem);
    right: clamp(1rem, 3vw, 2rem);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 4px;
    color: var(--label);
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.6);
    pointer-events: none;
  }
  .stage-title-eyebrow {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .stage-title-logo {
    width: auto;
    height: clamp(28px, 5vw, 52px);
    max-width: min(60%, 260px);
    object-fit: contain;
    object-position: left center;
    filter: drop-shadow(0 2px 10px rgba(0, 0, 0, 0.6));
  }
  .stage-title-main {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.1rem, 2.6vw, 1.6rem);
    letter-spacing: -0.01em;
  }
  .stage-title-sub {
    font-size: clamp(0.72rem, 1.6vw, 0.9rem);
    color: var(--label-secondary);
  }

  /* Centre play affordance */
  .stage-bigplay {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    display: grid;
    place-items: center;
    width: clamp(56px, 9vw, 84px);
    height: clamp(56px, 9vw, 84px);
    padding: 0;
    border-radius: var(--radius-pill);
    border: 1px solid var(--glass-border);
    background: var(--glass-strong);
    backdrop-filter: blur(12px) saturate(1.4);
    -webkit-backdrop-filter: blur(12px) saturate(1.4);
    color: var(--label);
    box-shadow: var(--shadow-md);
    transition: transform var(--dur-fast) var(--ease-out),
      background-color var(--dur-fast) var(--ease-out);
  }
  .stage-bigplay:hover {
    transform: translate(-50%, -50%) scale(1.06);
    background: var(--accent);
    color: rgb(6, 20, 13);
  }
  .stage-bigplay svg[data-icon="play"] {
    margin-left: 4px;
  }

  /* ── Control overlay ───────────────────────────────────────── */
  .stage-controls {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: clamp(0.75rem, 2.5vw, 1.5rem) clamp(1rem, 3vw, 2rem)
      clamp(0.9rem, 2.5vw, 1.5rem);
    display: flex;
    flex-direction: column;
    gap: clamp(0.35rem, 1.2vw, 0.6rem);
  }

  /* Thumbnail preview bubble — 160×90 (16:9), floats ~18px above the bar */
  .scrub-thumb {
    position: absolute;
    bottom: calc(100% - clamp(1rem, 3vw, 2rem) + 18px);
    left: 0;
    width: clamp(120px, 20vw, 160px);
    aspect-ratio: 16 / 9;
    transform: translateX(-50%);
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.3);
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.5);
    opacity: 0;
    transition: opacity var(--dur-fast) var(--ease-out);
    pointer-events: none;
    background-color: var(--emerald-depths);
  }
  .scrub-thumb.is-visible {
    opacity: 1;
  }
  /* Two cross-fading frame layers — background-position is nudged per bucket
     so distinct regions of the real backdrop read as distinct frames. */
  .scrub-thumb-frame {
    position: absolute;
    inset: 0;
    background-size: 180% auto;
    background-position: 50% 50%;
    opacity: 0;
    transition: opacity 0.18s ease-in-out;
  }
  .scrub-thumb-frame.is-active {
    opacity: 1;
  }
  .scrub-thumb-badge {
    position: absolute;
    top: 5px;
    left: 5px;
