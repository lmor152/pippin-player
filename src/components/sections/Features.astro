---
/**
 * Features — id="features".
 * The breadth catch-all: a scannable grid of glass cards conveying how much
 * Pippin does. Consistent line/duotone inline SVG icons tinted with --accent,
 * a tight title, and a one-line description each. Staggered scroll-reveal.
 */

const features = [
  {
    title: 'Custom pages & shelves',
    desc: 'Build your home from scratch — add, reorder, rename shelves and whole pages.',
    icon: 'layout',
  },
  {
    title: 'Shelf styles',
    desc: 'Show any shelf as a Row, a Spotlight carousel, or a full-bleed Hero.',
    icon: 'shelves',
  },
  {
    title: 'Accent & themes',
    desc: 'Pick any accent to re-tint the whole app. Light, Dark, and True Black for OLED.',
    icon: 'palette',
  },
  {
    title: 'Poster sizes',
    desc: 'From compact grids to big cinematic artwork — tuned per shelf.',
    icon: 'poster',
  },
  {
    title: 'Offline downloads',
    desc: 'Take your library on the go, played by the very same engine.',
    icon: 'download',
  },
  {
    title: 'Theme songs',
    desc: "Hear a show's theme as you browse it, on both Plex and Jellyfin.",
    icon: 'music',
  },
  {
    title: 'Multiple servers',
    desc: 'Combine Plex and Jellyfin servers with per-network profiles.',
    icon: 'servers',
  },
  {
    title: 'Continue Watching',
    desc: 'Pick up exactly where you left off, with the next episode ready.',
    icon: 'resume',
  },
  {
    title: 'Rich metadata',
    desc: 'IMDb, TMDb, Trakt, Rotten Tomatoes, Metacritic and Letterboxd ratings.',
    icon: 'ratings',
  },
  {
    title: 'Skip intro & credits',
    desc: 'Jump straight to the good part with marker-aware playback controls.',
    icon: 'skip',
  },
  {
    title: 'Live TV & Music',
    desc: 'Tune into live channels and play your whole music library.',
    icon: 'livetv',
  },
  {
    title: 'Search everywhere',
    desc: 'Find anything across every connected server, instantly.',
    icon: 'search',
  },
];
---

<section class="section" id="features">
  <div class="container">
    <div class="features-head reveal">
      <p class="eyebrow">Everything else</p>
      <h2 class="section-title">Polished down to the last pixel.</h2>
      <p class="section-subtitle">
        Dozens of thoughtful touches, all themeable, all yours to arrange. Here's
        a taste of what else is waiting inside.
      </p>
    </div>

    <ul class="features-grid" role="list">
      {features.map((f, i) => (
        <li
          class="feature-card glass reveal"
          style={`--reveal-delay:${Math.min(i * 60, 480)}ms`}
        >
          <span class="feature-icon" aria-hidden="true">
            {f.icon === 'layout' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2.5" />
                <path d="M3 9h18M9 9v12" />
              </svg>
            )}
            {f.icon === 'shelves' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="4.5" height="16" rx="1" />
                <rect x="9.75" y="4" width="4.5" height="16" rx="1" />
                <rect x="16.5" y="4" width="4.5" height="16" rx="1" />
              </svg>
            )}
            {f.icon === 'palette' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 3a9 9 0 1 0 0 18c1.4 0 2-.9 2-1.8 0-.5-.2-.9-.5-1.2-.3-.3-.5-.7-.5-1.2 0-.9.8-1.6 1.7-1.6H16a5 5 0 0 0 5-5c0-3.9-4-7-9-7Z" />
                <circle cx="7.5" cy="10.5" r="1" fill="currentColor" stroke="none" />
                <circle cx="12" cy="7.5" r="1" fill="currentColor" stroke="none" />
                <circle cx="16.5" cy="10.5" r="1" fill="currentColor" stroke="none" />
              </svg>
            )}
            {f.icon === 'poster' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <rect x="4" y="3" width="16" height="18" rx="2" />
                <path d="m8 15 2.5-3 2 2.2L15 11l3 4" />
                <circle cx="9" cy="8" r="1.4" />
              </svg>
            )}
            {f.icon === 'download' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 3v11m0 0 4-4m-4 4-4-4" />
                <path d="M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2" />
              </svg>
            )}
            {f.icon === 'music' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 18V6l11-2v11" />
                <circle cx="6" cy="18" r="3" />
                <circle cx="17" cy="15" r="3" />
              </svg>
            )}
            {f.icon === 'servers' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="7" rx="2" />
                <rect x="3" y="13" width="18" height="7" rx="2" />
                <path d="M7 7.5h.01M7 16.5h.01" />
              </svg>
            )}
            {f.icon === 'resume' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="9" />
                <path d="m10 9 5 3-5 3V9Z" fill="currentColor" stroke="none" />
              </svg>
            )}
            {f.icon === 'ratings' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 3.5l2.6 5.3 5.9.9-4.2 4.1 1 5.8-5.3-2.8L6.7 19.6l1-5.8L3.5 9.7l5.9-.9L12 3.5Z" />
              </svg>
            )}
            {f.icon === 'skip' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 6l7 6-7 6V6Z" fill="currentColor" stroke="none" />
                <path d="M17 6v12" />
              </svg>
            )}
            {f.icon === 'livetv' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="7" width="18" height="12" rx="2" />
                <path d="m8 4 4 3 4-3" />
              </svg>
            )}
            {f.icon === 'search' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="6.5" />
                <path d="m20 20-3.6-3.6" />
              </svg>
            )}
          </span>
          <div class="feature-body">
            <h3 class="feature-title">{f.title}</h3>
            <p class="feature-desc">{f.desc}</p>
          </div>
        </li>
      ))}
    </ul>

    <p class="features-more reveal" style="--reveal-delay:120ms">
      …and there's so much more.
    </p>
  </div>
</section>

<style>
  .features-head {
    max-width: 44rem;
    margin: 0 auto var(--space-8);
    text-align: center;
  }

  .features-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 960px) {
    .features-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .feature-card {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    padding: var(--space-5);
    border-radius: var(--radius-lg);
    transition:
      transform var(--dur) var(--ease-out),
      border-color var(--dur) var(--ease-out),
      box-shadow var(--dur) var(--ease-out);
    will-change: transform;
  }

  .feature-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent-muted, var(--accent));
    box-shadow: var(--shadow-glow);
  }

  .feature-icon {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-card);
    color: var(--accent);
    background: var(--accent-subtle);
    box-shadow: inset 0 0 0 1px var(--glass-border, var(--hairline));
    transition:
      background-color var(--dur) var(--ease-out),
      transform var(--dur) var(--ease-out);
  }

  .feature-card:hover .feature-icon {
    transform: scale(1.06);
  }

  .feature-icon svg {
    width: 24px;
    height: 24px;
    display: block;
  }

  .feature-body {
    min-width: 0;
  }

  .feature-title {
    font-family: var(--font-display, var(--font-body));
    font-size: 1.0625rem;
    font-weight: 650;
    line-height: 1.25;
    margin: 0 0 var(--space-2);
    color: var(--label);
    letter-spacing: -0.01em;
  }

  .feature-desc {
    font-size: 0.9375rem;
    line-height: 1.5;
    margin: 0;
    color: var(--label-secondary);
    text-wrap: pretty;
  }

  .features-more {
    margin: var(--space-8) auto 0;
    text-align: center;
    font-family: var(--font-display, var(--font-body));
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--label-tertiary);
    letter-spacing: -0.01em;
  }

  @media (prefers-reduced-motion: reduce) {
    .feature-card,
    .feature-icon {
      transition: none;
    }
    .feature-card:hover {
      transform: none;
    }
    .feature-card:hover .feature-icon {
      transform: none;
    }
  }
</style>
